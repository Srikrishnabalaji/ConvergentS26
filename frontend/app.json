{
  "expo": {
    "name": "WavePoint",
    "slug": "wavepoint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wavepoint",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby places.",
      "NSLocationAlwaysUsageDescription": "This app uses your location in the background.",
      "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to provide location-based features.",
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.wavepoint"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.wavepoint"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow WavePoint to use your location to show you on the map and provide directions."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow WavePoint to access the microphone for voice search.",
          "speechRecognitionPermission": "Allow WavePoint to use speech recognition for voice search."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
